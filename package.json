{
  "name": "local-expo-mcp",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "bin": {
    "local-expo-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "homepage": "https://github.com/salafidurus/local-expo-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/salafidurus/local-expo-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/salafidurus/local-expo-mcp/issues"
  },
  "keywords": [
    "expo",
    "mcp",
    "local",
    "codex",
    "mobile",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run clean && tsc -p tsconfig.json",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:windows": "vitest run --config vitest.windows.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:live:windows": "vitest run --config vitest.live-windows.config.ts",
    "test:acceptance": "bunx vitest run && bunx vitest run --config vitest.windows.config.ts && bunx vitest run --config vitest.live.config.ts && bunx vitest run --config vitest.live-windows.config.ts",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "release:prepare-pr": "tsx scripts/create-release-pr.ts",
    "release:publish": "npm publish --provenance --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "expo-mcp": "^0.2.4",
    "fast-xml-parser": "^5.5.8",
    "mobile-mcp": "0.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
